PORT=5000
CLIENT_URL=http://localhost:5173
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
ADMIN_EMAILS=admin@learnenglish.local
ADMIN_DEMO_PASSWORD=admin123

# MySQL is optional for local demo mode. Fill these to persist auth users/profiles.
DB_HOST=
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Cloudinary signed upload for images/avatar and optional raw/video uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
